{
  "manifest_version": 3,
  "name": "PhantomHand",
  "version": "1.0",
  "description": "AI Agent omnipotent browser controller utilizing CDP, Set-of-Mark vision, and a stealth execution engine.",
  "permissions": [
    "activeTab",
    "tabs",
    "debugger",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    },
    "default_popup": "popup.html",
    "default_title": "PhantomHand Control Panel"
  }
}
